# NeoDataRemoval — Environment Configuration
# Copy this to .env and fill in your values

# Server
PORT=3000
PUBLIC_PORT=3000
# Public URL used in outbound emails (e.g. monthly reports)
APP_URL=http://localhost:3000

# Security — REQUIRED: generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_generate_a_long_random_string

# Encryption key for profile data at rest — REQUIRED: generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change_me_32_byte_hex_string_64chars

# Proxy — set to 1 if running behind nginx/traefik so real client IPs are respected
TRUST_PROXY=0

# Registration — set to "closed" after initial setup to prevent new accounts
ADMIN_REGISTRATION=open

# OpenAI — optional, only needed for AI-assisted removal email drafting
OPENAI_API_KEY=

# Email (nodemailer) — optional, for sending removal emails and notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=NeoDataRemoval <noreply@yourdomain.com>
